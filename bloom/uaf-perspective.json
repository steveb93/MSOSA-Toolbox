  "searchPhrases": [
    {
      "name": "Show all capabilities",
      "description": "Every Capability node with its name caption.",
      "query": "MATCH (c:Capability) RETURN c"
    },
    {
      "name": "Capability traceability for $capability",
      "description": "Forward closure of REALISES* / TRACES_TO* from one Capability — surfaces every dependent operational/resource element. Provide the Capability name when prompted.",
      "query": "MATCH (c:Capability {name: $capability})<-[r:REALISES|REALISED_BY|TRACES_TO|EXHIBITS|IMPLEMENTS|PERFORMS*1..4]-(n) RETURN c, r, n",
      "parameters": [
        { "name": "capability", "displayName": "Capability name", "defaultValue": "" }
      ]
    },
    {
      "name": "Operational activities and their performers",
      "description": "Activities joined to the performers that execute them via PERFORMS.",
      "query": "MATCH (p:OperationalPerformer)-[r:PERFORMS]->(a:OperationalActivity) RETURN p, r, a"
    },
    {
      "name": "Resources realising $capability",
      "description": "ResourcePerformers reachable via the REALISES chain from a named Capability.",
      "query": "MATCH (c:Capability {name: $capability})<-[r:REALISES|EXHIBITS*1..3]-(rp:ResourcePerformer) RETURN c, r, rp",
      "parameters": [
        { "name": "capability", "displayName": "Capability name", "defaultValue": "" }
      ]
    },
    {
      "name": "AS-IS vs TO-BE elements in $domain",
      "description": "Sub-package partitioning (Dassault UAF Way-of-Working convention): elements whose qualifiedName contains AS-IS or TO-BE under the named domain. Use 'Operational' or 'Strategic' as $domain.",
      "query": "MATCH (n) WHERE n.stereotype IS NOT NULL AND n.qualifiedName CONTAINS $domain AND (n.qualifiedName CONTAINS 'AS-IS' OR n.qualifiedName CONTAINS 'TO-BE') RETURN n",
      "parameters": [
        { "name": "domain", "displayName": "Domain (e.g. Operational, Strategic)", "defaultValue": "Operational" }
      ]
    },
    {
      "name": "Decommissioning impact for $element",
      "description": "Forward impact closure from an element being retired — every node reachable via REALISES*, EXHIBITS*, TRACES_TO* that depends on it.",
      "query": "MATCH (e {name: $element})<-[r:REALISES|EXHIBITS|TRACES_TO|DEPENDS_ON*1..5]-(n) WHERE e.stereotype IS NOT NULL RETURN e, r, n",
      "parameters": [
        { "name": "element", "displayName": "Element name", "defaultValue": "" }
      ]
    },
    {
      "name": "Capability gap — capabilities with no realising performer",
      "description": "Strategic Capabilities lacking any inbound REALISES from a ResourcePerformer or OperationalPerformer.",
      "query": "MATCH (c:Capability) WHERE NOT EXISTS { (c)<-[:REALISES|EXHIBITS]-(:ResourcePerformer) } AND NOT EXISTS { (c)<-[:REALISES|EXHIBITS]-(:OperationalPerformer) } RETURN c"
    },
    {
      "name": "Security dominance chain from $enclave",
      "description": "Transitive closure of DOMINATES from a named SecurityEnclave — the lattice the OWL TransitiveProperty axiom closes in Fuseki, here walked natively in Cypher.",
      "query": "MATCH (e:SecurityEnclave {name: $enclave})-[r:DOMINATES*1..]->(d) RETURN e, r, d",
      "parameters": [
        { "name": "enclave", "displayName": "SecurityEnclave name", "defaultValue": "" }
      ]
    }
  ]
}
