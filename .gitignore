# IDE / editor
.vscode/
.idea/

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/

# Claude Code local data
.claude/

# Logs
*.log

# Generated A-Box (large, refreshed after every MSOSA export — re-run dump_to_rdf.py)
ontology/dump/

# Maven build output
msosa-model-exporter/target/

# Atomic-write tempfiles from editor tools
**/*.java.tmp.*
**/*.py.tmp.*

# Local credentials / licence files — must never be committed
secrets/
*.license

# Docker compose environment files — credentials and per-machine paths.
# `.env.example` is committed as a template; real `.env` files never are.
.env
**/.env
