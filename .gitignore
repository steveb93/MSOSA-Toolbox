# IDE / editor
.vscode/
.idea/

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
# Python build outputs from `python -m build` (wheel + sdist).
# Repo-root /build and /dist anchor to the top so a future plugin
# called build/ or dist/ wouldn't get caught.
/build/
/dist/

# Claude Code local data
.claude/

# Logs
*.log

# Generated A-Box (large, refreshed after every MSOSA export — re-run dump_to_rdf.py).
# Track only the placeholder uaf-instance.ttl so a fresh clone can boot Fuseki
# without needing a Neo4j export first; ignore every other artefact in here.
# The placeholder is the 13-line stub committed in 35caddb — never replace it
# with real dump content in a commit (dump_to_rdf.py overwrites the working
# tree at runtime; do not `git add` the result).
ontology/dump/*
!ontology/dump/uaf-instance.ttl

# Throwaway TTL produced by concatenating uaf-mvo.ttl + uaf-mvo-axioms.ttl for
# upload to https://service.tib.eu/webvowl/ — WebVOWL's UI only accepts one file.
#  Get-Content ontology\uaf-mvo.ttl, ontology\uaf-mvo-axioms.ttl | Set-Content ontology\uaf-mvo-combined.ttl
ontology/uaf-mvo-combined.ttl

# Maven build output
msosa-model-exporter/target/

# Maven Versions Plugin backup (suppressed by `bump-version.ps1` via -DgenerateBackupPoms=false,
# but a manual `mvn versions:set-property` without that flag will produce one).
**/pom.xml.versionsBackup

# Atomic-write tempfiles from editor tools
**/*.java.tmp.*
**/*.py.tmp.*

# Local credentials / licence files — must never be committed
secrets/
*.license

# Docker compose environment files — credentials and per-machine paths.
# `.env.example` is committed as a template; real `.env` files never are.
.env
**/.env
