{
  "title": "UAF Starter",
  "version": "2.4",
  "settings": {
    "pagenumber": 0,
    "editable": true,
    "fullscreenEnabled": false,
    "parameters": {}
  },
  "pages": [
    {
      "title": "Strategic",
      "reports": [
        {
          "id": "p1-r1",
          "title": "Show all capabilities",
          "query": "MATCH (c:Capability) RETURN c LIMIT 200",
          "type": "graph",
          "x": 0, "y": 0, "width": 12, "height": 4,
          "selection": {},
          "settings": {
            "nodeColorScheme": "neo4j",
            "showPropertiesOnHover": true
          }
        },
        {
          "id": "p1-r2",
          "title": "Pick a capability",
          "query": "",
          "type": "select",
          "x": 0, "y": 4, "width": 3, "height": 2,
          "selection": {},
          "settings": {
            "type": "Node Property",
            "entityType": "Capability",
            "propertyType": "name",
            "parameterName": "neodash_capability",
            "manualParameterSave": false,
            "clearParameterOnFieldClear": false
          }
        },
        {
          "id": "p1-r3",
          "title": "Capability traceability for $neodash_capability",
          "query": "MATCH p = shortestPath((c:Capability {name: $neodash_capability})<-[:REALISES|EXHIBITS|IMPLEMENTS|PERFORMS*1..4]-(n)) WHERE n <> c RETURN p LIMIT 200",
          "type": "graph",
          "x": 3, "y": 4, "width": 5, "height": 5,
          "selection": {},
          "settings": {}
        },
        {
          "id": "p1-r4",
          "title": "Performers realising $neodash_capability",
          "query": "MATCH p = shortestPath((c:Capability {name: $neodash_capability})<-[:REALISES|EXHIBITS*1..3]-(rp)) WHERE rp <> c RETURN p LIMIT 200",
          "type": "graph",
          "x": 8, "y": 4, "width": 4, "height": 5,
          "selection": {},
          "settings": {}
        },
        {
          "id": "p1-r5",
          "title": "Capability gap — capabilities with no realising performer",
          "query": "MATCH (c:Capability) WHERE NOT EXISTS { (c)<-[:REALISES|EXHIBITS]-() } RETURN c.name AS Capability, c.qualifiedName AS QualifiedName ORDER BY Capability",
          "type": "table",
          "x": 0, "y": 6, "width": 3, "height": 3,
          "selection": {},
          "settings": {}
        }
      ]
    },
    {
      "title": "Operational",
      "reports": [
        {
          "id": "p2-r1",
          "title": "Operational activities and their performers",
          "query": "MATCH (p)-[r:PERFORMS]->(a:OperationalActivity) RETURN p, r, a",
          "type": "graph",
          "x": 0, "y": 0, "width": 12, "height": 5,
          "selection": {},
          "settings": {}
        },
        {
          "id": "p2-r2",
          "title": "Pick an element by name",
          "query": "",
          "type": "select",
          "x": 0, "y": 5, "width": 3, "height": 2,
          "selection": {},
          "settings": {
            "type": "Free Text",
            "parameterName": "neodash_element",
            "manualParameterSave": false,
            "clearParameterOnFieldClear": false
          }
        },
        {
          "id": "p2-r3",
          "title": "Decommissioning impact for $neodash_element",
          "query": "MATCH (e {name: $neodash_element}) WHERE e.stereotype IS NOT NULL MATCH p = shortestPath((e)<-[:REALISES|EXHIBITS|IMPLEMENTS|PERFORMS|DEPENDENCY|RESOURCEEXCHANGE|MESSAGE_FLOW|ITEMFLOW*1..5]-(n)) WHERE n <> e RETURN p LIMIT 200",
          "type": "graph",
          "x": 3, "y": 5, "width": 9, "height": 5,
          "selection": {},
          "settings": {}
        },
        {
          "id": "p2-r4",
          "title": "Pick a domain (Operational / Strategic / Resource ...)",
          "query": "",
          "type": "select",
          "x": 0, "y": 7, "width": 3, "height": 2,
          "selection": {},
          "settings": {
            "type": "Free Text",
            "parameterName": "neodash_domain",
            "manualParameterSave": false,
            "clearParameterOnFieldClear": false,
            "defaultValue": "Operational"
          }
        },
        {
          "id": "p2-r5",
          "title": "AS-IS vs TO-BE elements in $neodash_domain",
          "query": "MATCH (n)-[r:REALISES|EXHIBITS|IMPLEMENTS|PERFORMS|DEPENDENCY|RESOURCEEXCHANGE|MESSAGE_FLOW|ITEMFLOW]-(m) WHERE n.stereotype IS NOT NULL AND n.qualifiedName CONTAINS $neodash_domain AND (n.qualifiedName CONTAINS 'AS-IS' OR n.qualifiedName CONTAINS 'TO-BE') RETURN n, r, m LIMIT 200",
          "type": "graph",
          "x": 3, "y": 7, "width": 9, "height": 5,
          "selection": {},
          "settings": {}
        }
      ]
    },
    {
      "title": "Security",
      "reports": [
        {
          "id": "p3-r1",
          "title": "Pick a security enclave",
          "query": "",
          "type": "select",
          "x": 0, "y": 0, "width": 3, "height": 2,
          "selection": {},
          "settings": {
            "type": "Node Property",
            "entityType": "SecurityEnclave",
            "propertyType": "name",
            "parameterName": "neodash_enclave",
            "manualParameterSave": false,
            "clearParameterOnFieldClear": false
          }
        },
        {
          "id": "p3-r2",
          "title": "Security dominance chain from $neodash_enclave",
          "query": "MATCH p = shortestPath((e:SecurityEnclave {name: $neodash_enclave})-[:DOMINATES*1..5]->(d)) WHERE d <> e RETURN p LIMIT 200",
          "type": "graph",
          "x": 3, "y": 0, "width": 9, "height": 6,
          "selection": {},
          "settings": {}
        }
      ]
    }
  ],
  "extensions": {
    "active": true,
    "activeReducers": []
  },
  "parameters": {}
}
