{
  "mcpServers": {
    "local-neo4j-database-claude": {
      "command": "python",
      "args": ["-m", "graph_mcp_driver.server"],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "<set to the same value as docker-compose/.env NEO4J_PASSWORD>",
        "NEO4J_DATABASE": "neo4j",
        "NEO4J_NAMESPACE": "local"
      }
    }
  }
}
