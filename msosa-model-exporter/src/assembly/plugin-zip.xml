<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0
                              http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>plugin</id>
    <formats><format>zip</format></formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <!--
      MSOSA / MagicDraw Resource Manager zip layout. The zip is unpacked
      INTO the modeling-tool install directory, so it must mirror that
      directory's structure exactly:

          data/resourcemanager/MDR_Plugin_<name>_<id>_descriptor.xml
          plugins/<plugin-id>/<payload>

      The descriptor's <file from="..."/> paths are zip-relative; <file
      to="..."/> paths are install-dir-relative. The two match here
      because we mirror the install tree.

      Background on prior failed layouts (Issue #86):
        * Flat zip with descriptor.xml at root  -> "'files' directory is
          not found" (misleading: real problem is wrong layout entirely).
        * descriptor.xml + files/<payload>      -> "Error reading
          descriptor file" (descriptor wasn't where the Resource Manager
          looks: data/resourcemanager/).
    -->
    <files>
        <file>
            <source>${project.build.directory}/${project.artifactId}-${project.version}.jar</source>
            <outputDirectory>plugins/com.uaf.neo4j.plugin</outputDirectory>
        </file>
        <file>
            <source>src/main/resources/plugin.xml</source>
            <outputDirectory>plugins/com.uaf.neo4j.plugin</outputDirectory>
            <filtered>true</filtered>
        </file>
        <file>
            <source>src/main/resources/neo4j-connection.properties</source>
            <outputDirectory>plugins/com.uaf.neo4j.plugin</outputDirectory>
        </file>
        <file>
            <source>src/main/resources/descriptor.xml</source>
            <outputDirectory>data/resourcemanager</outputDirectory>
            <destName>MDR_Plugin_MSOSA_Model_Exporter_30086_descriptor.xml</destName>
            <filtered>true</filtered>
        </file>
    </files>
</assembly>
