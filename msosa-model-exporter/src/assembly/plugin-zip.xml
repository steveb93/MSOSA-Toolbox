<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0
                              http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>plugin</id>
    <formats><format>zip</format></formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <!--
      MagicDraw Resource/Plugin Manager expects the standard resource zip
      layout: descriptor.xml at the zip root, all payload files inside a
      sibling 'files/' directory. Each <file from="X" to="Y"/> inside
      descriptor.xml resolves X relative to that files/ directory and
      installs to <MSOSA_HOME>/Y.

      Previous flat layout (everything at root) triggered "'files'
      directory is not found" — Issue #86 follow-on, comment dated
      2026-05-24.
    -->
    <files>
        <file>
            <source>${project.build.directory}/${project.artifactId}-${project.version}.jar</source>
            <outputDirectory>files</outputDirectory>
        </file>
        <file>
            <source>src/main/resources/plugin.xml</source>
            <outputDirectory>files</outputDirectory>
            <filtered>true</filtered>
        </file>
        <file>
            <source>src/main/resources/neo4j-connection.properties</source>
            <outputDirectory>files</outputDirectory>
        </file>
        <file>
            <source>src/main/resources/descriptor.xml</source>
            <outputDirectory>.</outputDirectory>
            <filtered>true</filtered>
        </file>
    </files>
</assembly>
