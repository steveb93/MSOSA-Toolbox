# Copy this file to `.env` in the same directory before bringing the stack up:
#   cp docker-compose/.env.example docker-compose/.env
#
# `.env` is gitignored. Do not commit real credentials.

# Neo4j admin password (database user is always `neo4j`).
NEO4J_PASSWORD=changeme

# Absolute host path where Neo4j stores data/logs/import/plugins. The four
# subdirs are created on first run. Pick a location outside the repo to keep
# database files out of git history.
#   Windows example: NEO4J_DATA_DIR=F:/neo4j-docker
#   Linux/macOS:     NEO4J_DATA_DIR=/var/lib/neo4j-docker
NEO4J_DATA_DIR=

# Fuseki admin password (overlay only — required when running docker-compose.fuseki.yml).
FUSEKI_ADMIN_PASSWORD=changeme

# Fuseki JVM heap (overlay only). Default 8g — sized for OWL FB reasoner with
# the full uaf-mvo-axioms.ttl axiom set against a typical export. Reasoning
# queries that enumerate reasoner-derived inverses GC-thrash below 8g. Drop
# to 4g on constrained dev machines if you only run the /uaf-raw/sparql
# endpoint; raise for larger models.
FUSEKI_HEAP=8g
