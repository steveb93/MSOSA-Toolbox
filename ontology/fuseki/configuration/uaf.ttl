## Fuseki assembler config for the UAF SPARQL endpoint.
## Loaded automatically because it lives in /fuseki/configuration.
##
## The dataset is an in-memory model containing:
##   - uaf-mvo.ttl         (T-Box, generated from UAFStereotypeRegistry)
##   - uaf-mvo-axioms.ttl  (Stage 3 OWL axioms — inverses, disjointness,
##                          dominance transitivity, CapabilityConfiguration
##                          restrictions; hand-authored, sibling to MVO)
##   - uml-data-marking.ttl (DoD classification levels + dominance lattice for
##                          UML-side data marking on ERD Entities. Layered on
##                          tv_securityClassification literals from the
##                          MSOSA traverser; separate namespace from uaf:.)
##   - dump/uaf-instance.ttl (A-Box, dumped from Neo4j by dump_to_rdf.py)
##
## Reasoner: OWL FB rule reasoner (OWLFBRuleReasoner). Stage 3 upgraded this
## from RDFS-Exp to materialise OWL property chains, owl:inverseOf, and
## class disjointness. The previous RDFS-Exp reasoner ignored every axiom
## in uaf-mvo-axioms.ttl. Trade-off: OWL FB is slower at load time than
## RDFS-Exp because it expands a larger rule set; query-time performance is
## comparable for the MVO size. Revisit if the materialised dataset grows
## past a few hundred thousand triples.

@prefix :       <#> .
@prefix fuseki: <http://jena.apache.org/fuseki#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ja:     <http://jena.hpl.hp.com/2005/11/Assembler#> .

## Two services share one base model:
##   /uaf/sparql      — OWL FB reasoning (semantic queries: subsumption, SHACL,
##                      inverseOf-derived edges, disjointness checks)
##   /uaf-raw/sparql  — base model only, no inference (analytical queries that
##                      consume directly-emitted triples: GDS recommender,
##                      ranking, raw counts). Much faster; no reasoner overhead.
##
## Both expose the same underlying triples — the raw service is the unreasoned
## view of what the reasoning service infers over. Choose per query: if it
## needs uaf:realisedBy (inverse-of-derived), point at /uaf/sparql; if it
## needs uaf:realises (directly emitted), /uaf-raw/sparql is the cheap path.

:service a fuseki:Service ;
    fuseki:name     "uaf" ;
    fuseki:endpoint [ fuseki:operation fuseki:query  ; fuseki:name "sparql" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:query  ; fuseki:name "query"  ] ;
    fuseki:endpoint [ fuseki:operation fuseki:update ; fuseki:name "update" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:gsp-rw ; fuseki:name "data"   ] ;
    fuseki:dataset  :dataset .

:raw_service a fuseki:Service ;
    fuseki:name     "uaf-raw" ;
    fuseki:endpoint [ fuseki:operation fuseki:query ; fuseki:name "sparql" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:query ; fuseki:name "query"  ] ;
    fuseki:dataset  :raw_dataset .

:dataset a ja:RDFDataset ;
    ja:defaultGraph :inf_model .

:raw_dataset a ja:RDFDataset ;
    ja:defaultGraph :base_model .

:inf_model a ja:InfModel ;
    ja:baseModel :base_model ;
    ja:reasoner  [ ja:reasonerURL <http://jena.hpl.hp.com/2003/OWLFBRuleReasoner> ] .

:base_model a ja:MemoryModel ;
    ja:content [ ja:externalContent <file:///staging/uaf-mvo.ttl> ] ;
    ja:content [ ja:externalContent <file:///staging/uaf-mvo-axioms.ttl> ] ;
    ja:content [ ja:externalContent <file:///staging/uml-data-marking.ttl> ] ;
    ja:content [ ja:externalContent <file:///staging/dump/uaf-instance.ttl> ] .
