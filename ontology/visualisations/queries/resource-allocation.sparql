# Resource allocation view — Performers, Roles, Architecture, Artifacts.
#
# Mirrors the §5 OWL restrictions and Stage-3 SHACL shapes for the
# Resource domain: performers perform functions, roles assigned to
# performers, architecture composed of resources, artifacts allocated to
# performers/roles.

PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
  ?performer rdf:type uaf:ResourcePerformer ;
             rdfs:label ?performerLabel ;
             uaf:performs ?function .

  ?role rdf:type uaf:ResourceRole ;
        rdfs:label ?roleLabel ;
        uaf:assignedTo ?performer .

  ?arch rdf:type uaf:ResourceArchitecture ;
        rdfs:label ?archLabel ;
        uaf:composedOf ?component .

  ?artifact rdf:type uaf:ResourceArtifact ;
            rdfs:label ?artifactLabel ;
            uaf:allocatedTo ?target .

  ?function rdfs:label ?functionLabel ;
            uaf:domain ?functionDomain .

  ?component rdfs:label ?componentLabel ;
             uaf:domain ?componentDomain .

  ?target rdfs:label ?targetLabel ;
          uaf:domain ?targetDomain .
}
WHERE {
  {
    ?performer a uaf:ResourcePerformer ;
               rdfs:label ?performerLabel .
    OPTIONAL { ?performer uaf:performs ?function .
               ?function rdfs:label ?functionLabel ;
                         uaf:domain ?functionDomain . }
  } UNION {
    ?role a uaf:ResourceRole ;
          rdfs:label ?roleLabel .
    OPTIONAL { ?role uaf:assignedTo ?performer .
               ?performer rdfs:label ?performerLabel . }
  } UNION {
    ?arch a uaf:ResourceArchitecture ;
          rdfs:label ?archLabel .
    OPTIONAL { ?arch uaf:composedOf ?component .
               ?component rdfs:label ?componentLabel ;
                          uaf:domain ?componentDomain . }
  } UNION {
    ?artifact a uaf:ResourceArtifact ;
              rdfs:label ?artifactLabel .
    OPTIONAL { ?artifact uaf:allocatedTo ?target .
               ?target rdfs:label ?targetLabel ;
                       uaf:domain ?targetDomain . }
  }
}
