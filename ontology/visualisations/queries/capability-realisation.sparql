# Capability realisation chain — Strategic → Operational → Resource.
#
# Returns every Capability together with the CapabilityConfiguration(s) that
# realise it and the operational/resource elements those configurations are
# realised by. Useful for seeing how strategic intent is wired down to
# physical realisation in one picture.
#
# Forward + reverse predicates both included so the result graph survives
# whichever direction the model authors used (OWL FB materialises both).

PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
  ?cap rdf:type uaf:Capability ;
       rdfs:label ?capLabel ;
       uaf:exhibits ?effect ;
       uaf:realisedBy ?cfg .

  ?cfg rdf:type uaf:CapabilityConfiguration ;
       rdfs:label ?cfgLabel ;
       uaf:realisedBy ?realiser .

  ?realiser rdf:type ?realiserType ;
            rdfs:label ?realiserLabel ;
            uaf:domain ?realiserDomain .

  ?effect rdf:type uaf:DesiredEffect ;
          rdfs:label ?effectLabel .
}
WHERE {
  ?cap a uaf:Capability ;
       rdfs:label ?capLabel .
  OPTIONAL { ?cap uaf:exhibits ?effect .
             ?effect rdfs:label ?effectLabel . }
  OPTIONAL {
    ?cfg a uaf:CapabilityConfiguration ;
         rdfs:label ?cfgLabel ;
         uaf:realises ?cap .
    OPTIONAL {
      ?realiser uaf:realises ?cfg ;
                a ?realiserType ;
                rdfs:label ?realiserLabel ;
                uaf:domain ?realiserDomain .
    }
  }
}
