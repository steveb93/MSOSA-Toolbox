# Security accreditation view — Risks, Controls, ControlFamilies, Assets.
#
# The structural shape SHACL fires on: every SecurityAsset should be
# contributed to by ≥1 SecurityControl; every SecurityRisk should be
# traced by ≥1 SecurityControl; every SecurityControl should be contained
# in a SecurityControlFamily.

PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
  ?risk rdf:type uaf:SecurityRisk ;
        rdfs:label ?riskLabel ;
        uaf:tracedBy ?control .

  ?control rdf:type uaf:SecurityControl ;
           rdfs:label ?controlLabel ;
           uaf:containedIn ?family ;
           uaf:contributesTo ?asset .

  ?family rdf:type uaf:SecurityControlFamily ;
          rdfs:label ?familyLabel .

  ?asset rdf:type uaf:SecurityAsset ;
         rdfs:label ?assetLabel .
}
WHERE {
  {
    ?control a uaf:SecurityControl ;
             rdfs:label ?controlLabel .
    OPTIONAL { ?control uaf:tracesTo ?risk .
               ?risk rdfs:label ?riskLabel . }
    OPTIONAL { ?control uaf:containedIn ?family .
               ?family rdfs:label ?familyLabel . }
    OPTIONAL { ?control uaf:contributesTo ?asset .
               ?asset rdfs:label ?assetLabel . }
  } UNION {
    ?risk a uaf:SecurityRisk ;
          rdfs:label ?riskLabel .
  } UNION {
    ?asset a uaf:SecurityAsset ;
           rdfs:label ?assetLabel .
  }
}
