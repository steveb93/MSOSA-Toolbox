# Operational flow view — Activities, Performers, Processes.
#
# Mirrors the §5 OWL restrictions and Stage-3 SHACL shapes for the
# Operational domain: activities performed by performers, processes
# composed of activities.

PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
  ?activity rdf:type uaf:OperationalActivity ;
            rdfs:label ?activityLabel ;
            uaf:performedBy ?performer .

  ?performer rdf:type uaf:OperationalPerformer ;
             rdfs:label ?performerLabel .

  ?process rdf:type uaf:OperationalProcess ;
           rdfs:label ?processLabel ;
           uaf:composedOf ?activity .
}
WHERE {
  {
    ?activity a uaf:OperationalActivity ;
              rdfs:label ?activityLabel .
    OPTIONAL { ?activity uaf:performedBy ?performer .
               ?performer rdfs:label ?performerLabel . }
  } UNION {
    ?performer a uaf:OperationalPerformer ;
               rdfs:label ?performerLabel .
  } UNION {
    ?process a uaf:OperationalProcess ;
             rdfs:label ?processLabel .
    OPTIONAL { ?process uaf:composedOf ?activity .
               ?activity rdfs:label ?activityLabel . }
  }
}
