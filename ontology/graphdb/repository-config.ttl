## GraphDB repository config for the UAF MVO browser.
## POSTed to /rest/repositories by the graphdb-loader sidecar in
## docker-compose.graphdb.yml on first start; idempotent on subsequent restarts.
##
## Ruleset is rdfsplus-optimized so the visual graph respects the same RDFS
## subclass / subproperty closure that the Fuseki overlay already uses
## (closest match to Fuseki's RDFSExptRuleReasoner in GraphDB's built-in set).

@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rep:     <http://www.openrdf.org/config/repository#> .
@prefix sr:      <http://www.openrdf.org/config/repository/sail#> .
@prefix sail:    <http://www.openrdf.org/config/sail#> .
@prefix graphdb: <http://www.ontotext.com/config/graphdb#> .

[] a rep:Repository ;
    rep:repositoryID "uaf" ;
    rdfs:label "UAF MVO Graph (T-Box + A-Box)" ;
    rep:repositoryImpl [
        rep:repositoryType "graphdb:SailRepository" ;
        sr:sailImpl [
            sail:sailType "graphdb:Sail" ;
            graphdb:ruleset "rdfsplus-optimized" ;
            graphdb:base-URL "http://msosa-toolbox.local/uaf#" ;
            graphdb:repository-type "file-repository" ;
            graphdb:storage-folder "storage" ;
            graphdb:enable-context-index "true" ;
            graphdb:enable-predicate-list "true" ;
            graphdb:enable-literal-index "true" ;
            graphdb:check-for-inconsistencies "false" ;
            graphdb:disable-sameAs "true" ;
            graphdb:query-timeout "0" ;
            graphdb:read-only "false"
        ]
    ] .
