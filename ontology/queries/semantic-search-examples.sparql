# Semantic-search anchor queries for the LLM-fronted UAF use case.
# Each query is independent; copy one into run_sparql via the MCP tool.
#
# Each query declares its own PREFIX lines because Fuseki does not inject
# prefixes server-side. The namespaces in use:
#   uaf:      http://msosa-toolbox.local/uaf#
#   uafprop:  http://msosa-toolbox.local/uaf/prop#
#   uafgds:   http://msosa-toolbox.local/uaf/gds#
#   sysml:    http://msosa-toolbox.local/sysml#
#   bpmn:     http://msosa-toolbox.local/bpmn#
#
# -----------------------------------------------------------------------------
#  Generate a combined Turtle file for Visualisation 
#
#  Get-Content ontology\uaf-mvo.ttl, ontology\uaf-mvo-axioms.ttl, ontology\uml-data-marking.ttl | Set-Content ontology\uaf-mvo-combined.ttl
#
#  Then in https://service.tib.eu/webvowl/ choose Ontology → Select ontology file → uaf-mvo-combined.ttl. The class diagram will
#  show all the MVO classes from uaf-mvo.ttl plus the Stage-3 axioms from uaf-mvo-axioms.ttl rendered on the class cards:
#
#  - owl:inverseOf arrows (e.g. realises ↔ realisedBy)
#  - owl:disjointWith markers between domain superclasses
#  - owl:TransitiveProperty annotation on uaf:dominates
#  - owl:someValuesFrom cardinality restrictions on CapabilityConfiguration and the other 11 governed classes
#
# -----------------------------------------------------------------------------
# 1. All Capabilities by name
# Smoke test — confirms the endpoint reaches the MVG.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?capability ?name WHERE {
  ?capability a uaf:Capability ;
              rdfs:label ?name .
}
ORDER BY ?name
LIMIT 100

# -----------------------------------------------------------------------------
# 2. Subsumption — every Strategic element instance
# Returns Capability, Vision, EndState, … without naming each subclass.
# Proves the T-Box import worked (rdfs:subClassOf inference).
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?element ?type ?name WHERE {
  ?element a ?type ;
           rdfs:label ?name .
  ?type rdfs:subClassOf* uaf:StrategicElement .
}
ORDER BY ?type ?name
LIMIT 200

# -----------------------------------------------------------------------------
# 3. Canonical UAF chain — Capability -> OperationalActivity -> ResourceFunction
# The five-hop traceability cited in the Ontology-Approach doc §4.3.
# Multi-hop SPARQL property path; equivalent to a Cypher MATCH with three rel filters.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?capName ?opActName ?resFuncName WHERE {
  ?cap a uaf:Capability ;
       rdfs:label ?capName ;
       (uaf:realises|uaf:enables|uaf:supports)+ ?opAct .
  ?opAct a uaf:OperationalActivity ;
         rdfs:label ?opActName ;
         (uaf:allocatedTo|uaf:performs|uaf:implements)+ ?resFunc .
  ?resFunc a uaf:ResourceFunction ;
           rdfs:label ?resFuncName .
}
LIMIT 50

# -----------------------------------------------------------------------------
# 4. Orphan detection — Capabilities with no realising OperationalActivity
# Knowledge-discovery use case (Gartner §3.3). NOT EXISTS is the SPARQL clause.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?cap ?name WHERE {
  ?cap a uaf:Capability ;
       rdfs:label ?name .
  FILTER NOT EXISTS {
    ?cap (uaf:realises|uaf:enables|uaf:supports|uaf:exhibits) ?opAct .
    ?opAct a uaf:OperationalActivity .
  }
}
ORDER BY ?name

# -----------------------------------------------------------------------------
# 5. Cross-language — UAF Capabilities that trace to SysML Requirements
# Hybrid-ontology query. Mirrors init_uaf_graph.cypher cookbook query 14.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX sysml: <http://msosa-toolbox.local/sysml#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?capName ?reqName WHERE {
  ?cap a uaf:Capability ;
       rdfs:label ?capName ;
       (uaf:satisfies|uaf:tracesTo|uaf:refines) ?req .
  ?req a sysml:Requirement ;
       rdfs:label ?reqName .
}
ORDER BY ?capName

# -----------------------------------------------------------------------------
# 6. Resource artefacts contributing to a named Capability
# Recommendation-engine anchor: surface candidates that could fill a gap.
# Replace "CAPABILITY_NAME" with a real capability name from query 1.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT DISTINCT ?artefact ?artefactName ?artefactType WHERE {
  ?cap a uaf:Capability ;
       rdfs:label "CAPABILITY_NAME" .
  ?cap (uaf:realises|uaf:dependsOn|uaf:allocatedTo|uaf:composedOf)+ ?artefact .
  ?artefact a ?artefactType ;
            rdfs:label ?artefactName .
  ?artefactType rdfs:subClassOf* uaf:ResourceElement .
}
LIMIT 100

# -----------------------------------------------------------------------------
# 7. BPMN process tasks linked to UAF Operational Activities
# Cross-language traceability for hybrid models with BPMN process diagrams.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX bpmn: <http://msosa-toolbox.local/bpmn#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?taskName ?opActName WHERE {
  ?task a ?taskType ;
        rdfs:label ?taskName .
  ?taskType rdfs:subClassOf* bpmn:Task .
  ?task (uaf:implements|uaf:realises|uaf:tracesTo) ?opAct .
  ?opAct a uaf:OperationalActivity ;
         rdfs:label ?opActName .
}
ORDER BY ?opActName

# -----------------------------------------------------------------------------
# 8. Impact analysis — what would I lose if this OperationalActivity were removed
# "If I remove X, what Capabilities are degraded and what ResourceFunctions
# become stranded?" Cited in Ontology-Approach doc §8 (enterprise architects).
# Replace "ACTIVITY_NAME" with a real activity name.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?affected ?affectedType ?affectedName WHERE {
  ?opAct a uaf:OperationalActivity ;
         rdfs:label "ACTIVITY_NAME" .
  {
    ?cap (uaf:realises|uaf:enables|uaf:supports) ?opAct .
    ?cap a ?affectedType ;
         rdfs:label ?affectedName .
    BIND(?cap AS ?affected)
  } UNION {
    ?opAct (uaf:allocatedTo|uaf:performs|uaf:implements) ?resFunc .
    ?resFunc a ?affectedType ;
             rdfs:label ?affectedName .
    BIND(?resFunc AS ?affected)
  }
}


# -----------------------------------------------------------------------------
# 9. Most-influential elements by GDS PageRank
# Surfaces the elements that the most trace/realisation/exhibits paths
# converge on. Requires a prior `gds.pageRank.write('uaf-full', {writeProperty:
# 'gdsPagerank'})` run in Neo4j (see cypher/gds-cookbook.cypher §6a) and a
# subsequent `dump_to_rdf.py` refresh of Fuseki — GDS scores are written on
# the LPG side; the dump script materialises them as uafgds:pagerank triples.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX uafgds: <http://msosa-toolbox.local/uaf/gds#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?node ?name ?type ?pagerank WHERE {
  ?node uafgds:pagerank ?pagerank ;
        rdfs:label ?name ;
        a ?type .
  FILTER(STRSTARTS(STR(?type), STR(uaf:)))
}
ORDER BY DESC(?pagerank)
LIMIT 25

# -----------------------------------------------------------------------------
# 10. Capability-coverage gap (PageRank-weighted)
# Capabilities whose PageRank is high but which have no realisation trace to a
# RESOURCE-domain element are the most consequential coverage gaps in the
# current model — a strategic intent that nothing yet delivers. Requires the
# same GDS write-back as query 9.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX uafgds: <http://msosa-toolbox.local/uaf/gds#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?capability ?name ?pagerank WHERE {
  ?capability a uaf:Capability ;
              rdfs:label ?name ;
              uafgds:pagerank ?pagerank .
  FILTER NOT EXISTS {
    ?capability (uaf:realisedBy|uaf:exhibitedBy|uaf:tracedBy|uaf:implementedBy)+ ?resource .
    ?resource uaf:domain "RESOURCE" .
  }
}
ORDER BY DESC(?pagerank)
LIMIT 25

# -----------------------------------------------------------------------------
# 11. ResourceArtifact recommendations for a Capability gap (content-based)
# Given a Capability identified by query 10, this query ranks RESOURCE-domain
# elements by how many *other* Capabilities they already realise (peer-realiser
# frequency), with PageRank as the tie-break. Universal players surface first.
# Substitute the gap IRI into the FILTER. Used by the
# `recommend_resources_for_gap` MCP tool — see graph_mcp_driver/server.py.
# -----------------------------------------------------------------------------
PREFIX uaf: <http://msosa-toolbox.local/uaf#>
PREFIX uafgds: <http://msosa-toolbox.local/uaf/gds#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?resource ?name ?stereotype ?pagerank (COUNT(DISTINCT ?peer) AS ?peersRealised) WHERE {
  ?peer a uaf:Capability ;
        (uaf:realisedBy|uaf:exhibitedBy|uaf:tracedBy|uaf:implementedBy)+ ?resource .
  ?resource uaf:domain "RESOURCE" ;
            rdfs:label ?name ;
            a ?stereotype ;
            uafgds:pagerank ?pagerank .
  FILTER(?peer != <http://msosa-toolbox.local/uaf/instance#REPLACE_WITH_GAP_IRI>)
  FILTER(STRSTARTS(STR(?stereotype), STR(uaf:)))
}
GROUP BY ?resource ?name ?stereotype ?pagerank
ORDER BY DESC(?peersRealised) DESC(?pagerank)
LIMIT 10
