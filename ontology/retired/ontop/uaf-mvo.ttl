<http://msosa-toolbox.local/uaf/mvo> a owl:Ontology ;
    rdfs:label "UAF MVO (Strategic + Operational + Resource)" ;
    rdfs:comment "Minimum Viable Ontology covering UAF 1.2 stereotypes in the Strategic, Operational and Resource domains, generated from UAFStereotypeRegistry." ;
    owl:versionInfo "0.1.0" ;
    dcterms:created "2026-05-19"^^xsd:date .

# --- Domain abstract superclasses --------------------------------------------

uaf:StrategicElement a owl:Class ;
    rdfs:label "StrategicElement" ;
    rdfs:comment "Abstract superclass for UAF strategic domain elements." ;
    uafprop:domain "STRATEGIC" .

uaf:OperationalElement a owl:Class ;
    rdfs:label "OperationalElement" ;
    rdfs:comment "Abstract superclass for UAF operational domain elements." ;
    uafprop:domain "OPERATIONAL" .

uaf:ResourceElement a owl:Class ;
    rdfs:label "ResourceElement" ;
    rdfs:comment "Abstract superclass for UAF resource domain elements." ;
    uafprop:domain "RESOURCE" .

